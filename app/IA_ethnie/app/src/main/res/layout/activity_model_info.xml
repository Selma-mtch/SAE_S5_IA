<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="44dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="-12dp"
                android:padding="12dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/primary"
                android:contentDescription="Retour" />

            <TextView
                android:id="@+id/tvProjectTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="FaceAI"
                android:textColor="@color/text_primary"
                android:textSize="32sp"
                android:textStyle="bold"
                android:fontFamily="serif" />

            <TextView
                android:id="@+id/tvProjectDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Application de reconnaissance faciale intelligente"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp" />

            <View
                android:layout_width="40dp"
                android:layout_height="1dp"
                android:layout_marginTop="24dp"
                android:background="@color/accent" />

        </LinearLayout>

        <!-- ====== Section: Dataset ====== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01 — DATASET"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvDataset"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="6dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="28dp"
            android:layout_marginTop="24dp"
            android:background="@color/divider" />

        <!-- ====== Section: Modeles ====== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="02 — MODELES IA"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvModels"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="6dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="28dp"
            android:layout_marginTop="24dp"
            android:background="@color/divider" />

        <!-- ====== Section: Metriques ====== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="03 — METRIQUES"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvMetrics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="6dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="28dp"
            android:layout_marginTop="24dp"
            android:background="@color/divider" />

        <!-- ====== Section: Technologies ====== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="04 — TECHNOLOGIES"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvTech"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="6dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="28dp"
            android:layout_marginTop="24dp"
            android:background="@color/divider" />

        <!-- ====== Section: Classes ====== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="05 — CLASSES"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvEthnicities"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="6dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
